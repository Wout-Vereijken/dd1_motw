import discord
import requests
from bs4 import BeautifulSoup
import os

TOKEN = os.environ["BOT_TOKEN"]
WIKI_URL = "https://dungeondefenders.wiki.gg/wiki/Map_of_the_Week"

intents = discord.Intents.default()
client = discord.Client(intents=intents)
tree = discord.app_commands.CommandTree(client)


def get_current_motw():
    r = requests.get(WIKI_URL, timeout=10)
    soup = BeautifulSoup(r.text, "html.parser")

    table = soup.find("table", class_="wikitable")
    cells = table.find_all("td")

    return {
        "promoted": cells[0].get_text(strip=True),
        "bonus": cells[1].get_text(strip=True),
        "starting": cells[2].get_text(strip=True)
    }


@tree.command(name="motw", description="Get current Map of the Week")
async def motw(interaction: discord.Interaction):
    data = get_current_motw()

    embed = discord.Embed(
        title="🗺️ Map of the Week",
        url=WIKI_URL,
        color=0x9999ff
    )

    embed.add_field(name="Promoted Map", value=data["promoted"], inline=True)
    embed.add_field(name="Bonus Map", value=data["bonus"], inline=True)
    embed.add_field(name="Starting", value=data["starting"], inline=False)

    await interaction.response.send_message(embed=embed)


@client.event
async def on_ready():
    await tree.sync()
    print(f"Logged in as {client.user}")


client.run(TOKEN)
